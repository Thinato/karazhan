.omc
/target

# karazhan runtime logs
.karazhan/logs/

# per-user project config (committed example lives at .karazhan/config.example.toml)
.karazhan/config.toml

# detached worktrees created via the "new worktree" modal (working copies).
# The default location is now $XDG_DATA_HOME/karazhan/worktrees/<owner>/<project>/<uuid>/
# (outside the repo). This entry covers repos that override worktrees_dir back
# inside the repo (e.g. worktrees_dir = ".karazhan/worktrees").
.karazhan/worktrees/

